[Unit]
Description=ASF Security Dashboard Backend

[Service]
Type=exec
WorkingDirectory=/opt/dashboard-backend
PIDFile=/opt/dashboard-backend/dashboard-backend-watch-label-renames.pid
ExecStart=/usr/local/bin/uv run security-dashboard-backend-watch-label-renames.py
ExecReload=/bin/kill -SIGINT $MAINPID
Restart=always

[Install]
WantedBy=multi-user.target
